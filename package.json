{
  "name": "resume-builder",
  "version": "1.0.0",
  "private": true,
  "description": "Local Vue.js tool to edit CV content and generate a LaTeX (.tex) / PDF resume from the resume.cls template structure.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "type-check": "vue-tsc --noEmit",
    "preview": "vite preview",
    "server": "node server/index.mjs"
  },
  "dependencies": {
    "pinia": "^2.3.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vue-tsc": "^2.2.0"
  }
}
